# انسخه باسم .env محليًا، أو حطّ القيم كـ Variables في Railway

# Railway Postgres+pgvector (استخدم الـ reference: ${{ pgvector.DATABASE_URL }})
DATABASE_URL=

# مفاتيح الـ APIs
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
APIFY_TOKEN=

# المصدر: apify (تغطية MENA) أو meta_api (الرسمي المجاني)
META_SOURCE=apify
USE_TIKTOK=true

# اختياري: لو META_SOURCE=meta_api
META_ACCESS_TOKEN=
META_API_VERSION=v22.0

# أسماء الـ Apify actors (اختر من Apify Store وعدّل المابينج لو لزم)
APIFY_META_ACTOR=curious_coder~facebook-ads-library-scraper
APIFY_TIKTOK_ACTOR=doliz~tiktok-creative-center-scraper